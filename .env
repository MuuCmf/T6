APP_DEBUG = true
APP_TRACE = true

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

[DATABASE]
TYPE = mysql
HOSTNAME = mysql
DATABASE = muucmf
USERNAME = muucmf
PASSWORD = muucmf_password
HOSTPORT = 3306
CHARSET = utf8
DEBUG = true
# 慢查询阈值（单位:毫秒）超过该时间会记录到日志
SLOW_LOG_TIME = 100
# 是否记录所有SQL（仅开发模式下生效）
LOG_ALL_SQL = false

[CACHE]
DRIVER = redis

[MYSQL]
ROOT_PASSWORD = muucmf_password
PORT = 3306

[REDIS]
HOST = redis
PORT = 6379
PASSWORD = 
SELECT = 0

[QUEUE]
NAME = default

[LANG]
default_lang = zh-cn

[AUTH]
auth_key = muucmf

[JWT]
SECRET= muucmf



